---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  listVersions,
  listSlugs,
  listSlugsByPillar,
  edgesForVersion,
  readSchemaFields,
  readSchemaMeta,
  pillarForSlug,
  PILLARS,
} from "../../../lib/schemas.ts";

export function getStaticPaths() {
  return listVersions().map((version) => ({ params: { version } }));
}

const { version } = Astro.params;
const slugs = listSlugs(version!);
const groups = listSlugsByPillar(version!);
const edges = edgesForVersion(version!);

// Pillar hex map — CSS vars cannot reach inlined SVG strings.
const pillarHex: Record<string, string> = {
  root:         "#5a5f70",
  entity:       "#4a5ab8",
  people:       "#b57028",
  governance:   "#7149b8",
  financials:   "#1f8262",
  metrics:      "#2774b8",
  product:      "#1b7aa1",
  market:       "#b64668",
  brand:        "#a23aa6",
  integrations: "#b55924",
  legal:        "#636e2d",
};

// Build the entity data map consumed by the client. One object per slug with
// all the information the detail panel needs — avoids any per-click fetch.
type EntityRow = {
  slug: string;
  pillar: string;
  title: string;
  description: string;
  fields: Array<{ name: string; type: string; required: boolean; description?: string }>;
  out: Array<{ to: string; label?: string }>;
  in:  Array<{ from: string; label?: string }>;
};

const byFrom = new Map<string, Array<{ to: string; label?: string }>>();
const byTo   = new Map<string, Array<{ from: string; label?: string }>>();
for (const e of edges) {
  if (!byFrom.has(e.from)) byFrom.set(e.from, []);
  byFrom.get(e.from)!.push({ to: e.to, label: e.label });
  if (!byTo.has(e.to)) byTo.set(e.to, []);
  byTo.get(e.to)!.push({ from: e.from, label: e.label });
}

const entities: Record<string, EntityRow> = {};
for (const slug of slugs) {
  const meta = readSchemaMeta(version!, slug);
  entities[slug] = {
    slug,
    pillar: pillarForSlug(version!, slug),
    title: meta.title ?? slug,
    description: meta.description ?? "",
    fields: readSchemaFields(version!, slug).map((f) => ({
      name: f.name,
      type: f.type,
      required: f.required,
      description: f.description,
    })),
    out: byFrom.get(slug) ?? [],
    in:  byTo.get(slug) ?? [],
  };
}

// Slug -> field count (server-rendered into sidebar).
const fieldCounts: Record<string, number> = {};
for (const slug of slugs) fieldCounts[slug] = entities[slug].fields.length;

// ─── Full relationship graph (rendered server-side) ──────────────────
// Circular chord diagram. Every entity is a node on a ring, ordered by
// pillar and then alphabetically so same-pillar nodes cluster. Every
// curated edge is a quadratic Bézier through the centre. Hover
// highlighting + click-through is wired up client-side.
const PILLAR_ORDER = [
  "root", "entity", "people", "governance", "financials",
  "metrics", "product", "market", "brand", "integrations", "legal",
];

function esc(s: string): string {
  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

function buildFullGraphSvg(): string {
  const ordered = slugs.slice().sort((a, b) => {
    const pa = PILLAR_ORDER.indexOf(entities[a].pillar);
    const pb = PILLAR_ORDER.indexOf(entities[b].pillar);
    return (pa - pb) || a.localeCompare(b);
  });

  const N = ordered.length;
  const W = 900, H = 700;
  const cx = W / 2, cy = H / 2;
  const rNode = 230, rLabel = 252;

  const pos: Record<string, { a: number; x: number; y: number; lx: number; ly: number }> = {};
  ordered.forEach((slug, i) => {
    const a = (i / N) * 2 * Math.PI - Math.PI / 2;
    pos[slug] = {
      a,
      x: cx + rNode * Math.cos(a),
      y: cy + rNode * Math.sin(a),
      lx: cx + rLabel * Math.cos(a),
      ly: cy + rLabel * Math.sin(a),
    };
  });

  // Edges: curve through centre. Deduplicate (from, to) pairs.
  const seen = new Set<string>();
  const edgesSvg: string[] = [];
  for (const e of edges) {
    const key = `${e.from}->${e.to}`;
    if (seen.has(key)) continue;
    seen.add(key);
    if (!pos[e.from] || !pos[e.to]) continue;
    const f = pos[e.from], t = pos[e.to];
    const color = pillarHex[entities[e.from].pillar] ?? "#555";
    edgesSvg.push(
      `<path class="xp-full__edge" d="M${f.x.toFixed(1)},${f.y.toFixed(1)} Q${cx},${cy} ${t.x.toFixed(1)},${t.y.toFixed(1)}" fill="none" stroke="${color}" stroke-width="1" opacity="0.3" data-from="${esc(e.from)}" data-to="${esc(e.to)}"/>`,
    );
  }

  // Nodes + labels. Labels rotate so they read outward on both sides.
  const nodesSvg = ordered.map((slug) => {
    const p = pos[slug];
    const e = entities[slug];
    const color = pillarHex[e.pillar] ?? "#555";
    const flip = Math.cos(p.a) < 0;
    const rotation = (p.a * 180) / Math.PI + (flip ? 180 : 0);
    const anchor = flip ? "end" : "start";
    return `
      <g class="xp-full__node" data-slug="${esc(slug)}" data-pillar="${esc(e.pillar)}">
        <circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="4.5" fill="${color}" stroke="#ffffff" stroke-width="1.25"/>
        <text x="${p.lx.toFixed(1)}" y="${p.ly.toFixed(1)}"
              transform="rotate(${rotation.toFixed(2)} ${p.lx.toFixed(1)} ${p.ly.toFixed(1)})"
              text-anchor="${anchor}" class="xp-full__label" fill="${color}">${esc(slug)}</text>
      </g>
    `;
  }).join("");

  return `
    <svg viewBox="0 0 ${W} ${H}" class="xp-full__svg" preserveAspectRatio="xMidYMid meet"
         role="img" aria-label="Full relationship graph for ${slugs.length} entities">
      <g class="xp-full__edges">${edgesSvg.join("")}</g>
      <g class="xp-full__nodes">${nodesSvg}</g>
    </svg>
  `;
}

const fullGraphSvg = buildFullGraphSvg();
---

<BaseLayout
  title={`CorpoSpec ${version} — Schema explorer`}
  description="Interactive explorer for every CorpoSpec schema. Search entities and fields, follow references, and inspect the data model one entity at a time."
  active="schemas"
>
  <section class="hero hero--compact">
    <div class="hero__eyebrow">
      <span class="badge badge--version">{version}</span>
      <span>Schema explorer</span>
    </div>
    <h1>Explore the data model</h1>
    <p class="lead">
      Search {slugs.length} entities and their fields. Pick an entity to see its
      fields, definitions, and both sides of every relationship.
    </p>
    <div class="cta-row">
      <a class="btn btn--ghost" href={`/schemas/${version}/`}>← back to schemas</a>
    </div>
  </section>

  <div class="xp">
    <div class="xp__toolbar">
      <div class="xp__search" role="search">
        <svg class="xp__search-icon" viewBox="0 0 16 16" aria-hidden="true">
          <circle cx="7" cy="7" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/>
          <line x1="11" y1="11" x2="14.5" y2="14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <input
          id="xp-search"
          type="search"
          placeholder="Search entities, titles, fields, descriptions…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search the schema catalog"
        />
        <kbd class="xp__search-kbd">/</kbd>
      </div>
      <div class="legend xp__pillars" id="xp-pillars" role="group" aria-label="Filter by pillar">
        <button class="chip chip--toggle" data-pillar="all" aria-pressed="true">
          <span class="pill-dot" style="color: var(--ink);"></span>All
        </button>
        {PILLARS.filter((p) => groups.some((g) => g.pillar.id === p.id)).map((p) => (
          <button
            class="chip chip--toggle"
            data-pillar={p.id}
            aria-pressed="true"
            style={`--pillar: ${p.color};`}
          >
            <span class="pill-dot" style={`color: ${p.color};`}></span>{p.label}
          </button>
        ))}
      </div>
    </div>

    <div class="xp__layout">
      <aside class="xp__aside" id="xp-aside" aria-label="Entity catalog">
        <div class="xp__aside-meta" id="xp-aside-meta">
          <span id="xp-count">{slugs.length}</span> entities
        </div>
        {groups.map(({ pillar, slugs: pillarSlugs }) => (
          <div class="xp-group" data-pillar={pillar.id}>
            <div class="xp-group__head" style={`--pillar: ${pillar.color};`}>
              <span class="pill-dot" style={`color: ${pillar.color};`}></span>
              <span class="xp-group__label">{pillar.label}</span>
              <span class="xp-group__count">{pillarSlugs.length}</span>
            </div>
            <ul class="xp-group__list" role="list">
              {pillarSlugs.map((slug) => (
                <li class="xp-item" data-slug={slug} data-pillar={pillar.id}>
                  <a href={`#entity=${slug}`} data-select={slug}>
                    <span class="xp-item__slug">{slug}</span>
                    <span class="xp-item__count">{fieldCounts[slug]}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </aside>

      <main class="xp__main" id="xp-main" tabindex="-1">
        <!-- Overview panel (shown when no entity is selected). -->
        <section class="xp-overview" id="xp-overview">
          <div class="xp-overview__stats">
            <div class="xp-stat">
              <span class="xp-stat__value">{slugs.length}</span>
              <span class="xp-stat__label">entities</span>
            </div>
            <div class="xp-stat">
              <span class="xp-stat__value">{groups.length}</span>
              <span class="xp-stat__label">pillars</span>
            </div>
            <div class="xp-stat">
              <span class="xp-stat__value">{edges.length}</span>
              <span class="xp-stat__label">relationships</span>
            </div>
            <div class="xp-stat">
              <span class="xp-stat__value">{slugs.reduce((n, s) => n + fieldCounts[s], 0)}</span>
              <span class="xp-stat__label">fields</span>
            </div>
          </div>
          <div class="xp-overview__hint">
            <strong>Pick an entity</strong> from the sidebar to inspect its
            fields and relationships, or search above to jump straight to a field.
          </div>

          <section class="xp-full" id="xp-full" aria-label="Full relationship graph">
            <header class="xp-full__head">
              <h2>Full relationship graph</h2>
              <p class="xp-full__hint">
                {slugs.length} entities, {edges.length} curated relationships, grouped by pillar
                around the ring. <strong>Hover a node</strong> to highlight its 1-hop neighborhood,
                <strong>click</strong> to open the entity. Edge colour = source pillar.
              </p>
            </header>
            <div class="xp-full__frame" set:html={fullGraphSvg} />
            <div class="xp-full__legend" aria-label="Pillar legend">
              {PILLARS.filter((p) => groups.some((g) => g.pillar.id === p.id)).map((p) => (
                <span class="xp-full__legend-item">
                  <span class="pill-dot" style={`color: ${p.color};`}></span>{p.label}
                </span>
              ))}
            </div>
          </section>
          <div class="xp-overview__grid">
            {slugs.map((slug) => {
              const e = entities[slug];
              const p = PILLARS.find((x) => x.id === e.pillar)!;
              const desc = (e.description || e.title || "").split("\n")[0];
              return (
                <a
                  class="xp-card"
                  data-slug={slug}
                  data-pillar={e.pillar}
                  href={`#entity=${slug}`}
                  data-select={slug}
                  style={`--pillar: ${p.color};`}
                >
                  <div class="xp-card__head">
                    <span class="pill-dot" style={`color: ${p.color};`}></span>
                    <span class="xp-card__pillar">{p.label}</span>
                    <span class="xp-card__count">{fieldCounts[slug]} fields</span>
                  </div>
                  <div class="xp-card__slug">{slug}</div>
                  {desc ? <div class="xp-card__desc">{desc}</div> : null}
                </a>
              );
            })}
          </div>
        </section>

        <!-- Detail panel (populated from JS when an entity is selected). -->
        <section class="xp-detail" id="xp-detail" hidden aria-live="polite"></section>
      </main>
    </div>
  </div>

  <script
    is:inline
    type="module"
    define:vars={{ version, entities, pillarHex, PILLARS: PILLARS.map((p) => ({ id: p.id, label: p.label, color: p.color })) }}
  >
    // ─── state ──────────────────────────────────────────────────────────
    const PILLAR_IDS = PILLARS.map((p) => p.id);
    const activePillars = new Set(PILLAR_IDS);
    let query = "";
    let selected = null;

    const $aside      = document.getElementById("xp-aside");
    const $asideMeta  = document.getElementById("xp-count");
    const $overview   = document.getElementById("xp-overview");
    const $detail     = document.getElementById("xp-detail");
    const $pillars    = document.getElementById("xp-pillars");
    const $search     = document.getElementById("xp-search");
    const $main       = document.getElementById("xp-main");

    // Pillar lookup helpers.
    function pillar(id) { return PILLARS.find((p) => p.id === id) ?? PILLARS[0]; }
    function hex(id) { return pillarHex[id] ?? "#555"; }

    // ─── search index ──────────────────────────────────────────────────
    // Flatten entity + field text into a single lowercase haystack per slug.
    const haystacks = Object.fromEntries(
      Object.values(entities).map((e) => [
        e.slug,
        [
          e.slug,
          e.title,
          e.description,
          ...e.fields.map((f) => `${f.name} ${f.type} ${f.description ?? ""}`),
        ]
          .join(" ")
          .toLowerCase(),
      ]),
    );

    function matches(slug) {
      const q = query.trim().toLowerCase();
      if (!q) return true;
      return haystacks[slug].includes(q);
    }
    function visible(slug) {
      return activePillars.has(entities[slug].pillar) && matches(slug);
    }

    // ─── sidebar + overview filtering ──────────────────────────────────
    function renderFilters() {
      let shown = 0;
      document.querySelectorAll(".xp-item").forEach((el) => {
        const slug = el.getAttribute("data-slug");
        const on = visible(slug);
        el.hidden = !on;
        if (on) shown++;
      });
      document.querySelectorAll(".xp-group").forEach((el) => {
        const pid = el.getAttribute("data-pillar");
        const anyVisible = Array.from(el.querySelectorAll(".xp-item")).some((li) => !li.hidden);
        el.hidden = !anyVisible || !activePillars.has(pid);
      });
      $asideMeta.textContent = String(shown);

      // Overview cards
      document.querySelectorAll(".xp-card").forEach((el) => {
        const slug = el.getAttribute("data-slug");
        el.hidden = !visible(slug);
      });

      // Chip aria-pressed.
      $pillars.querySelectorAll(".chip--toggle").forEach((btn) => {
        const p = btn.getAttribute("data-pillar");
        if (p === "all") {
          btn.setAttribute("aria-pressed", activePillars.size === PILLAR_IDS.length ? "true" : "false");
        } else {
          btn.setAttribute("aria-pressed", activePillars.has(p) ? "true" : "false");
        }
      });

      // If the selected entity got filtered out, fall back to overview.
      if (selected && !visible(selected)) selectEntity(null);
    }

    // ─── detail rendering ──────────────────────────────────────────────
    function escapeHtml(s) {
      return String(s ?? "").replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      })[c]);
    }

    function highlight(text, q) {
      if (!q) return escapeHtml(text);
      const t = String(text ?? "");
      const i = t.toLowerCase().indexOf(q.toLowerCase());
      if (i < 0) return escapeHtml(t);
      return (
        escapeHtml(t.slice(0, i)) +
        "<mark>" + escapeHtml(t.slice(i, i + q.length)) + "</mark>" +
        escapeHtml(t.slice(i + q.length))
      );
    }

    // Focused neighborhood SVG: center = current entity, ring = neighbors.
    // Outgoing edges drawn with arrow into the neighbor, incoming with arrow into centre.
    function renderNeighborhood(slug) {
      const e = entities[slug];
      const neighbors = [];
      const seen = new Set();
      for (const edge of e.out) {
        if (seen.has(`out:${edge.to}`)) continue;
        seen.add(`out:${edge.to}`);
        if (!entities[edge.to]) continue;
        neighbors.push({ slug: edge.to, dir: "out", label: edge.label ?? "" });
      }
      for (const edge of e.in) {
        if (seen.has(`in:${edge.from}`)) continue;
        seen.add(`in:${edge.from}`);
        if (!entities[edge.from]) continue;
        neighbors.push({ slug: edge.from, dir: "in", label: edge.label ?? "" });
      }

      if (neighbors.length === 0) {
        return `<div class="xp-neighbors xp-neighbors--empty">
          <span class="xp-neighbors__note">No curated relationships to other entities.</span>
        </div>`;
      }

      const W = 720, H = Math.max(320, 320 + Math.max(0, neighbors.length - 8) * 10);
      const cx = W / 2, cy = H / 2;
      const rx = Math.min(280, W / 2 - 110);
      const ry = Math.min(120, H / 2 - 60);

      // Place neighbors on an ellipse. Outgoing on the right half, incoming on the left.
      // Sort by direction + label for a stable layout.
      const outs = neighbors.filter((n) => n.dir === "out");
      const ins  = neighbors.filter((n) => n.dir === "in");

      function placeArc(nodes, startAngle, endAngle) {
        const n = nodes.length;
        if (n === 0) return [];
        return nodes.map((node, i) => {
          const t = n === 1 ? 0.5 : i / (n - 1);
          const a = startAngle + (endAngle - startAngle) * t;
          const x = cx + rx * Math.cos(a);
          const y = cy + ry * Math.sin(a);
          return { ...node, x, y };
        });
      }

      // Outgoing: right semicircle, top to bottom (−π/2 → π/2).
      // Incoming: left semicircle, bottom to top (π/2 → 3π/2).
      const placedOut = placeArc(outs, -Math.PI / 2, Math.PI / 2);
      const placedIn  = placeArc(ins, Math.PI / 2, (3 * Math.PI) / 2);
      const placed = [...placedOut, ...placedIn];

      const centerPillar = e.pillar;
      const centerHex = hex(centerPillar);

      // Edges first so nodes render on top.
      const edges = placed.map((n) => {
        const nhex = hex(entities[n.slug].pillar);
        // Trim line endpoints so arrowheads don't overlap the node rect.
        const dx = n.x - cx, dy = n.y - cy;
        const len = Math.sqrt(dx * dx + dy * dy) || 1;
        const sx = cx + (dx / len) * 70;  // skip past centre node
        const sy = cy + (dy / len) * 24;
        const tx = n.x - (dx / len) * 60;
        const ty = n.y - (dy / len) * 18;
        // Path direction: if outgoing, centre→neighbor. If incoming, neighbor→centre.
        const [x1, y1, x2, y2] = n.dir === "out" ? [sx, sy, tx, ty] : [tx, ty, sx, sy];
        const mid = { x: (x1 + x2) / 2, y: (y1 + y2) / 2 };
        return `
          <g class="xp-edge xp-edge--${n.dir}">
            <line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}"
                  stroke="${nhex}" stroke-width="1.25"
                  marker-end="url(#xp-arrow-${n.dir})" opacity="0.55"/>
            ${n.label ? `
              <rect x="${mid.x - (n.label.length * 3.2 + 8)}" y="${mid.y - 8}"
                    width="${n.label.length * 6.4 + 16}" height="16" rx="4"
                    fill="#ffffff" stroke="#e7e8ee" stroke-width="0.75"/>
              <text x="${mid.x}" y="${mid.y + 3.5}" class="xp-edge__label" text-anchor="middle">${escapeHtml(n.label)}</text>
            ` : ""}
          </g>
        `;
      }).join("");

      // Neighbor nodes.
      const nodes = placed.map((n) => {
        const ne = entities[n.slug];
        const nhex = hex(ne.pillar);
        const width = Math.max(100, n.slug.length * 7.2 + 24);
        return `
          <g class="xp-node xp-node--neighbor" data-slug="${escapeHtml(n.slug)}"
             transform="translate(${n.x - width / 2}, ${n.y - 18})">
            <rect width="${width}" height="36" rx="8" ry="8"
                  fill="#ffffff" stroke="${nhex}" stroke-width="1.5"/>
            <rect width="${width}" height="36" rx="8" ry="8" fill="${nhex}14"/>
            <text x="${width / 2}" y="22" text-anchor="middle" class="xp-node__label" fill="${nhex}">
              ${escapeHtml(n.slug)}
            </text>
          </g>
        `;
      }).join("");

      const centerWidth = Math.max(160, e.slug.length * 8.4 + 40);

      return `
        <div class="xp-neighbors" role="figure" aria-label="Relationships for ${escapeHtml(e.slug)}">
          <svg viewBox="0 0 ${W} ${H}" preserveAspectRatio="xMidYMid meet" class="xp-neighbors__svg">
            <defs>
              <marker id="xp-arrow-out" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
                <path d="M0,0 L10,5 L0,10 Z" fill="#7b8199"/>
              </marker>
              <marker id="xp-arrow-in" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
                <path d="M0,0 L10,5 L0,10 Z" fill="#7b8199"/>
              </marker>
            </defs>
            ${edges}
            ${nodes}
            <g class="xp-node xp-node--center" transform="translate(${cx - centerWidth / 2}, ${cy - 22})">
              <rect width="${centerWidth}" height="44" rx="10" ry="10"
                    fill="${centerHex}" stroke="${centerHex}" stroke-width="1.5"/>
              <text x="${centerWidth / 2}" y="27" text-anchor="middle" class="xp-node__label xp-node__label--center" fill="#ffffff">
                ${escapeHtml(e.slug)}
              </text>
            </g>
          </svg>
          <div class="xp-neighbors__legend">
            <span><span class="xp-neighbors__swatch xp-neighbors__swatch--out"></span>outgoing (${placedOut.length})</span>
            <span><span class="xp-neighbors__swatch xp-neighbors__swatch--in"></span>incoming (${placedIn.length})</span>
          </div>
        </div>
      `;
    }

    function renderFields(slug) {
      const e = entities[slug];
      if (e.fields.length === 0) {
        return `<p class="xp-empty">This schema defines no top-level fields directly.</p>`;
      }
      const q = query.trim();
      const rows = e.fields.map((f) => {
        const hay = `${f.name} ${f.type} ${f.description ?? ""}`.toLowerCase();
        const hit = q && hay.includes(q.toLowerCase());
        return `
          <tr${hit ? ' class="is-hit"' : ""}>
            <td><span class="name">${highlight(f.name, q)}</span></td>
            <td><span class="type">${highlight(f.type, q)}</span></td>
            <td><span class="req req--${f.required ? "yes" : "no"}">${f.required ? "yes" : "—"}</span></td>
            <td><span class="desc">${f.description ? highlight(f.description, q) : ""}</span></td>
          </tr>
        `;
      }).join("");
      return `
        <div class="fields">
          <table>
            <thead>
              <tr>
                <th style="width: 22%;">Field</th>
                <th style="width: 22%;">Type</th>
                <th style="width: 10%;">Required</th>
                <th>Description</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
      `;
    }

    function renderReferences(slug) {
      const e = entities[slug];
      if (e.out.length === 0 && e.in.length === 0) return "";
      function chips(list, dir) {
        if (list.length === 0) return `<span class="xp-empty">—</span>`;
        return list.map((r) => {
          const other = dir === "out" ? r.to : r.from;
          if (!entities[other]) return "";
          const op = pillar(entities[other].pillar);
          return `
            <a class="xp-ref" data-select="${escapeHtml(other)}" href="#entity=${escapeHtml(other)}" style="--pillar: ${op.color};">
              <span class="pill-dot" style="color: ${op.color};"></span>
              <span class="xp-ref__slug">${escapeHtml(other)}</span>
              ${r.label ? `<span class="xp-ref__label">${escapeHtml(r.label)}</span>` : ""}
            </a>
          `;
        }).join("");
      }
      return `
        <div class="xp-refs">
          <div class="xp-refs__col">
            <h3>References</h3>
            <p class="xp-refs__hint">Entities this one points to.</p>
            <div class="xp-refs__list">${chips(e.out, "out")}</div>
          </div>
          <div class="xp-refs__col">
            <h3>Referenced by</h3>
            <p class="xp-refs__hint">Entities that point to this one.</p>
            <div class="xp-refs__list">${chips(e.in, "in")}</div>
          </div>
        </div>
      `;
    }

    function renderDetail(slug) {
      const e = entities[slug];
      const p = pillar(e.pillar);
      return `
        <header class="xp-detail__head" style="--pillar: ${p.color};">
          <div class="xp-detail__eyebrow">
            <span class="pill-dot" style="color: ${p.color};"></span>
            <span>${escapeHtml(p.label)} pillar</span>
          </div>
          <h2 class="xp-detail__title">
            <span class="xp-detail__slug">${escapeHtml(e.slug)}</span>
            <span class="xp-detail__name">${escapeHtml(e.title)}</span>
          </h2>
          ${e.description ? `<p class="xp-detail__desc">${escapeHtml(e.description.split("\n")[0])}</p>` : ""}
          <div class="xp-detail__actions">
            <a class="btn btn--ghost" href="/schemas/${version}/${e.slug}/">Full reference →</a>
            <a class="btn btn--ghost" href="/schemas/${version}/${e.slug}.schema.json">Raw JSON</a>
          </div>
        </header>

        <section>
          <h3>Relationship neighborhood</h3>
          ${renderNeighborhood(slug)}
        </section>

        <section>
          <h3>Fields <span class="xp-count-inline">${e.fields.length}</span></h3>
          ${renderFields(slug)}
        </section>

        ${renderReferences(slug)}
      `;
    }

    function selectEntity(slug) {
      selected = slug;
      // Sidebar highlight.
      document.querySelectorAll(".xp-item.is-active").forEach((el) => el.classList.remove("is-active"));
      if (slug) {
        const li = document.querySelector(`.xp-item[data-slug="${slug}"]`);
        if (li) {
          li.classList.add("is-active");
          // Scroll into view within the sidebar if needed.
          const rect = li.getBoundingClientRect();
          const aRect = $aside.getBoundingClientRect();
          if (rect.top < aRect.top || rect.bottom > aRect.bottom) {
            li.scrollIntoView({ block: "nearest", behavior: "smooth" });
          }
        }
      }
      // Panels.
      if (slug && entities[slug]) {
        $detail.innerHTML = renderDetail(slug);
        $detail.hidden = false;
        $overview.hidden = true;
        document.title = `${entities[slug].slug} — CorpoSpec ${version}`;
      } else {
        $detail.innerHTML = "";
        $detail.hidden = true;
        $overview.hidden = false;
        document.title = `CorpoSpec ${version} — Schema explorer`;
      }
    }

    // ─── event wiring ──────────────────────────────────────────────────
    // Clicks on anything with [data-select].
    document.addEventListener("click", (ev) => {
      const a = ev.target.closest("[data-select]");
      if (!a) return;
      const slug = a.getAttribute("data-select");
      if (!slug || !entities[slug]) return;
      ev.preventDefault();
      history.pushState(null, "", `#entity=${slug}`);
      selectEntity(slug);
      // Scroll the main panel to top so header is visible.
      $main.scrollTo?.({ top: 0, behavior: "smooth" });
    });

    // Clicks on SVG neighbor nodes.
    $detail.addEventListener("click", (ev) => {
      const g = ev.target.closest(".xp-node--neighbor");
      if (!g) return;
      const slug = g.getAttribute("data-slug");
      if (!slug) return;
      history.pushState(null, "", `#entity=${slug}`);
      selectEntity(slug);
      $main.scrollTo?.({ top: 0, behavior: "smooth" });
    });

    // Pillar chip toggles.
    $pillars.addEventListener("click", (ev) => {
      const btn = ev.target.closest(".chip--toggle");
      if (!btn) return;
      const pid = btn.getAttribute("data-pillar");
      if (pid === "all") {
        const allOn = PILLAR_IDS.every((p) => activePillars.has(p));
        activePillars.clear();
        if (!allOn) PILLAR_IDS.forEach((p) => activePillars.add(p));
      } else {
        if (activePillars.has(pid)) activePillars.delete(pid);
        else activePillars.add(pid);
      }
      renderFilters();
    });

    // Search input with debounced re-render.
    let searchTimer = null;
    $search.addEventListener("input", () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        query = $search.value;
        renderFilters();
        // If an entity is selected, re-render to refresh field highlighting.
        if (selected) selectEntity(selected);
      }, 80);
    });

    // "/" keyboard shortcut focuses search.
    document.addEventListener("keydown", (ev) => {
      if (ev.key === "/" && !["INPUT", "TEXTAREA"].includes(document.activeElement?.tagName ?? "")) {
        ev.preventDefault();
        $search.focus();
        $search.select();
      }
      if (ev.key === "Escape" && document.activeElement === $search) {
        $search.blur();
      }
    });

    // Hash routing: #entity=<slug>.
    function readHash() {
      const h = location.hash.replace(/^#/, "");
      const m = h.match(/entity=([a-z0-9-]+)/i);
      return m ? m[1] : null;
    }
    window.addEventListener("hashchange", () => {
      const slug = readHash();
      selectEntity(slug && entities[slug] ? slug : null);
    });

    // ─── full graph hover/click ────────────────────────────────────────
    // Server renders the SVG; JS adds highlighting + navigation.
    const $fullGraph = document.getElementById("xp-full");
    if ($fullGraph) {
      const edges = Array.from($fullGraph.querySelectorAll(".xp-full__edge"));
      const nodes = Array.from($fullGraph.querySelectorAll(".xp-full__node"));

      // Precompute adjacency so hover doesn't scan edges each time.
      const adjacency = new Map(); // slug -> Set(connected slug + edge elements)
      const nodeBySlug = new Map();
      for (const n of nodes) {
        const s = n.getAttribute("data-slug");
        nodeBySlug.set(s, n);
        if (!adjacency.has(s)) adjacency.set(s, { peers: new Set(), edges: new Set() });
      }
      for (const edge of edges) {
        const f = edge.getAttribute("data-from");
        const t = edge.getAttribute("data-to");
        if (adjacency.has(f)) {
          adjacency.get(f).peers.add(t);
          adjacency.get(f).edges.add(edge);
        }
        if (adjacency.has(t)) {
          adjacency.get(t).peers.add(f);
          adjacency.get(t).edges.add(edge);
        }
      }

      function focusNode(slug) {
        if (!adjacency.has(slug)) return;
        const { peers, edges: incident } = adjacency.get(slug);
        for (const n of nodes) n.classList.remove("is-active");
        for (const e of edges) e.classList.remove("is-active");
        nodeBySlug.get(slug)?.classList.add("is-active");
        for (const p of peers) nodeBySlug.get(p)?.classList.add("is-active");
        for (const e of incident) e.classList.add("is-active");
        $fullGraph.classList.add("is-focus");
      }
      function clearFocus() {
        for (const n of nodes) n.classList.remove("is-active");
        for (const e of edges) e.classList.remove("is-active");
        $fullGraph.classList.remove("is-focus");
      }

      // Delegated hover. mouseover fires on children; find the nearest node.
      $fullGraph.addEventListener("mouseover", (ev) => {
        const n = ev.target.closest(".xp-full__node");
        if (!n) return;
        const slug = n.getAttribute("data-slug");
        if (slug) focusNode(slug);
      });
      $fullGraph.addEventListener("mouseleave", clearFocus);

      // Click: open the entity.
      $fullGraph.addEventListener("click", (ev) => {
        const n = ev.target.closest(".xp-full__node");
        if (!n) return;
        const slug = n.getAttribute("data-slug");
        if (!slug || !entities[slug]) return;
        ev.preventDefault();
        history.pushState(null, "", `#entity=${slug}`);
        selectEntity(slug);
        $main.scrollTo?.({ top: 0, behavior: "smooth" });
      });
    }

    // Initial paint.
    renderFilters();
    const initial = readHash();
    if (initial && entities[initial]) selectEntity(initial);
  </script>

  <style is:global>
    /* Must be global: the detail panel, neighborhood SVG, fields table, and
       relationship chips are all injected via innerHTML from the client
       script. Astro's scoped `data-astro-cid-*` attributes are only applied
       to server-rendered markup, so scoping this block would leave all
       dynamic sub-views unstyled. The `.xp-*` / `.fields` namespace is
       page-specific enough to remain effectively local. */

    /* ─── compact hero ─────────────────────────────────────────────── */
    .hero--compact { padding: 48px 0 24px; margin-bottom: 24px; }
    .hero--compact .lead { font-size: 17px; }

    /* ─── explorer shell ───────────────────────────────────────────── */
    /* No `overflow: hidden` here: that would turn `.xp` into the sticky
       ancestor for the toolbar and aside without giving them a real scroll
